    "# 1D CNN\n",
    "class AnomalyCNN(nn.Module):\n",
    "    def __init__(self, input_channels, window_size):\n",
    "        super(AnomalyCNN, self).__init__()\n",
    "        self.conv_block = nn.Sequential(\n",
    "            nn.Conv1d(input_channels, 32, kernel_size=3, padding=1),\n",
    "            nn.BatchNorm1d(32),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv1d(32, 64, kernel_size=3, padding=1),\n",
    "            nn.BatchNorm1d(64),\n",
    "            nn.ReLU(),\n",
    "            nn.AdaptiveAvgPool1d(1)\n",
    "        )\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(64, 32),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.2),\n",
    "            nn.Linear(32, 1)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.conv_block(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        return self.fc(x)\n",
    "\n",
    "#Training\n",
    "WINDOW_SIZE = 10\n",
    "train_ds = SensorDataset(X_scaled, y_raw, window_size=WINDOW_SIZE)\n",
    "train_loader = DataLoader(train_ds, batch_size=1024, shuffle=True)\n",
    "\n",
    "model = AnomalyCNN(input_channels=len(sensors), window_size=WINDOW_SIZE).to(device)\n",
    "\n",
    "pos_weight = torch.tensor([(len(y_raw) - sum(y_raw)) / sum(y_raw)]).to(device)\n",
    "criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)\n",
    "optimizer = optim.Adam(model.parameters(), lr=0.001)\n",
    "\n",
    "#Loop\n",
    "print(\"Training 1D-CNN(This may take a while on CPU, use GPU if possible)...\")\n",
    "model.train()\n",
    "for epoch in range(3):\n",
    "    total_loss = 0\n",
    "    for batch_x, batch_y in train_loader:\n",
    "        batch_x, batch_y = batch_x.to(device), batch_y.to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        outputs = model(batch_x)\n",
    "        loss = criterion(outputs, batch_y)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    print(f\"Epoch {epoch+1} | Loss: {total_loss/len(train_loader):.4f}\")\n",
    "\n",
    "\n",
    "print(\"Generating predictions...\")\n",
    "model.eval()\n",
    "test_ds = SensorDataset(X_test_scaled, window_size=WINDOW_SIZE)\n",
    "test_loader = DataLoader(test_ds, batch_size=2048, shuffle=False)\n",
    "\n",
    "preds = []\n",
    "with torch.no_grad():\n",
    "    for batch_x in test_loader:\n",
    "        batch_x = batch_x.to(device)\n",
    "        output = torch.sigmoid(model(batch_x))\n",
    "        preds.extend(output.cpu().numpy())\n",
    "\n",
    "final_preds = [0] * WINDOW_SIZE + [1 if p > 0.5 else 0 for p in preds]"
   ]
  },
