   "source": [
    "#Feature selection\n",
    "sensors = ['X1', 'X2', 'X3', 'X4', 'X5']\n",
    "X_raw = train[sensors].values\n",
    "y_raw = train['target'].astype(int).values\n",
    "X_test_raw = test[sensors].values\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X_raw)\n",
    "X_test_scaled = scaler.transform(X_test_raw)\n",
    "\n",
    "#Windowing\n",
    "class SensorDataset(Dataset):\n",
    "    def __init__(self, X, y=None, window_size=10):\n",
    "        self.X = X\n",
    "        self.y = y\n",
    "        self.window_size = window_size\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.X) - self.window_size\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        window = self.X[idx : idx + self.window_size]\n",
    "        window = torch.FloatTensor(window).permute(1, 0)\n",
    "        \n",
    "        if self.y is not None:\n",
    "            label = torch.FloatTensor([self.y[idx + self.window_size]])\n",
    "            return window, label\n",
    "        return window"
   ]
  },
