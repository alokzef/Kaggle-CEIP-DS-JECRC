    "def engineer_features(df: pd.DataFrame, is_train: bool = True) -> pd.DataFrame:\n",
    "    \"\"\"Apply all feature engineering steps to a dataframe.\"\"\"\n",
    "    d = df.copy()\n",
    "\n",
    "    d['X3_log'] = np.log(d['X3'].clip(lower=1e-9))          \n",
    "    d['X4_log'] = np.log(d['X4'].clip(lower=1e-9))      \n",
    "    # X5 is ln(k)  \n",
    "    d['X5_exp'] = np.exp(d['X5'])                           \n",
    "\n",
    "\n",
    "    d['year']       = d['Date'].dt.year\n",
    "    d['month']      = d['Date'].dt.month\n",
    "    d['day']        = d['Date'].dt.day\n",
    "    d['dayofweek']  = d['Date'].dt.dayofweek   \n",
    "    d['quarter']    = d['Date'].dt.quarter\n",
    "    d['dayofyear']  = d['Date'].dt.dayofyear\n",
    "    d['weekofyear'] = d['Date'].dt.isocalendar().week.astype(int)\n",
    "    d['is_weekend'] = (d['dayofweek'] >= 5).astype(int)\n",
    "\n",
    "\n",
    "    d['X1_X2_ratio']  = d['X1'] / (d['X2'] + 1e-9)\n",
    "    d['X1_X2_diff']   = d['X1'] - d['X2']\n",
    "    d['X1_X2_prod']   = d['X1'] * d['X2']\n",
    "    d['X3_X4_diff']   = d['X3_log'] - d['X4_log']           \n",
    "    d['X3_X4_ratio']  = d['X3_log'] / (d['X4_log'] + 1e-9)\n",
    "    d['X5_X4_ratio']  = d['X5_exp'] / (d['X4_log'] + 1e-9)\n",
    "\n",
    "    d['X1_log'] = np.log(d['X1'].clip(lower=1e-9))\n",
    "    d['X2_log'] = np.log(d['X2'].clip(lower=1e-9))\n",
    "\n",
    "    d.drop(columns=['Date'], inplace=True)\n",
    "\n",
    "    return d\n",
    "\n",
    "\n",
    "train_fe = engineer_features(train_raw, is_train=True)\n",
    "test_fe  = engineer_features(test_raw,  is_train=False)\n",
    "\n",
    "print('Features after engineering:')\n",
    "feature_cols = [c for c in train_fe.columns if c not in ['target']]\n",
    "print(feature_cols)\n",
    "print(f'\\nTotal features: {len(feature_cols)}')"
   ]
