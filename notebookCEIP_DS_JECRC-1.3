    "def evaluate_model(name, model, X_tr, y_tr, X_v, y_v, verbose=True):\n",
    "    \"\"\"Fit model, predict on val, return metrics dict.\"\"\"\n",
    "    model.fit(X_tr, y_tr)\n",
    "    preds = model.predict(X_v)\n",
    "\n",
    "    acc   = accuracy_score(y_v, preds)\n",
    "    prec  = precision_score(y_v, preds, zero_division=0)\n",
    "    rec   = recall_score(y_v, preds, zero_division=0)\n",
    "    f1    = f1_score(y_v, preds, zero_division=0)\n",
    "    f1_w  = f1_score(y_v, preds, average='weighted', zero_division=0)\n",
    "    try:\n",
    "        proba = model.predict_proba(X_v)[:, 1]\n",
    "        auc   = roc_auc_score(y_v, proba)\n",
    "    except Exception:\n",
    "        auc = float('nan')\n",
    "\n",
    "    result = dict(Model=name, Accuracy=acc, Precision=prec,\n",
    "                  Recall=rec, F1_class1=f1, F1_weighted=f1_w, ROC_AUC=auc)\n",
    "    if verbose:\n",
    "        print(f'\\n── {name} ──')\n",
    "        print(classification_report(y_v, preds, target_names=['Normal(0)', 'Anomaly(1)']))\n",
    "    return result\n",
    "\n",
    "\n",
    "results = []  # collect all model results"
   ]
  },
