    "# =========================================================\n",
    "# 1. IMPORTS\n",
    "# =========================================================\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from sklearn.preprocessing import RobustScaler\n",
    "from sklearn.metrics import f1_score, classification_report\n",
    "from sklearn.model_selection import TimeSeriesSplit\n",
    "from sklearn.ensemble import IsolationForest\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "from imblearn.over_sampling import SMOTE\n",
    "\n",
    "import xgboost as xgb\n",
    "import lightgbm as lgb\n",
    "\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers\n",
    "\n",
    "# =========================================================\n",
    "# 2. LOAD DATA\n",
    "# =========================================================\n",
    "train = pd.read_parquet('/kaggle/input/competitions/ceip-ds-jecrc/train.parquet')\n",
    "test  = pd.read_parquet('/kaggle/input/competitions/ceip-ds-jecrc/test.parquet')\n",
    "\n",
    "train['target'] = train['target'].astype(int)\n",
    "\n",
    "ratio = (train['target']==0).sum()/(train['target']==1).sum()\n",
    "print(\"Class ratio:\", ratio)\n",
    "\n",
    "# =========================================================\n",
    "# 3. FEATURE ENGINEERING (FIXED)\n",
    "# =========================================================\n",
    "def engineer(df, stats=None, iso=None):\n",
    "    d = df.copy()\n",
    "    d['Date'] = pd.to_datetime(d['Date'])\n",
    "    d = d.sort_values('Date').reset_index(drop=True)\n",
    "\n",
    "    # safe column handling\n",
    "    cols = [c for c in ['X1','X2','X3','X4','X5'] if c in d.columns]\n",
    "\n",
    "    # transforms\n",
    "    if 'X3' in d: d['X3'] = np.log1p(d['X3'].clip(lower=0))\n",
    "    if 'X4' in d: d['X4'] = np.log1p(d['X4'].clip(lower=0))\n",
    "    if 'X5' in d: d['X5'] = np.exp(d['X5'].clip(upper=10))\n",
    "\n",
    "    for c in cols:\n",
    "        r = d[c].rolling(20, min_periods=1)\n",
    "        d[f'{c}_mean'] = r.mean()\n",
    "        d[f'{c}_std'] = r.std().fillna(0)\n",
    "\n",
    "        d[f'{c}_diff'] = d[c].diff().fillna(0)\n",
    "\n",
    "        for lag in [1,2,3]:\n",
    "            d[f'{c}_lag_{lag}'] = d[c].shift(lag).fillna(0)\n",
    "\n",
    "    # FIXED stats logic\n",
    "    if stats is None:\n",
    "        stats = {}\n",
    "\n",
    "    zcols = []\n",
    "    for c in cols:\n",
    "        if c not in stats:\n",
    "            mu = d[c].mean()\n",
    "            sig = d[c].std() + 1e-4\n",
    "            stats[c] = (mu, sig)\n",
    "        else:\n",
    "            mu, sig = stats[c]\n",
    "\n",
    "        d[f'{c}_z'] = (d[c] - mu) / sig\n",
    "        zcols.append(f'{c}_z')\n",
    "\n",
    "    d['anom_count'] = (d[zcols].abs()>2).sum(axis=1)\n",
    "\n",
    "    # Isolation Forest\n",
    "    if iso is None:\n",
    "        iso = IsolationForest(contamination=0.01, random_state=42)\n",
    "        iso.fit(d[cols])\n",
    "\n",
    "    d['iso'] = -iso.score_samples(d[cols])\n",
    "    d['iso_rank'] = d['iso'].rank(pct=True)\n",
    "\n",
    "    d.drop(columns=['Date'], inplace=True)\n",
    "\n",
    "    return d, stats, iso\n",
    "\n",
    "\n",
    "train_df, stats, iso = engineer(train)\n",
    "test_df, _, _        = engineer(test, stats, iso)\n",
    "\n",
    "features = [c for c in train_df.columns if c not in ['target','ID','Id','id']]\n",
    "\n",
    "X = train_df[features].values\n",
    "y = train_df['target'].values\n",
    "X_test = test_df[features].values\n",
    "\n",
    "# scaling\n",
    "sc = RobustScaler()\n",
    "X = sc.fit_transform(X)\n",
    "X_test = sc.transform(X_test)\n",
    "\n",
    "# =========================================================\n",
    "# 4. TREE MODELS\n",
    "# =========================================================\n",
    "tscv = TimeSeriesSplit(n_splits=5)\n",
    "\n",
    "xgb_oof = np.zeros(len(y))\n",
    "lgb_oof = np.zeros(len(y))\n",
    "\n",
    "xgb_test = np.zeros(len(X_test))\n",
    "lgb_test = np.zeros(len(X_test))\n",
    "\n",
    "sm = SMOTE(sampling_strategy=0.1, random_state=42)\n",
    "\n",
    "for fold,(tr,va) in enumerate(tscv.split(X)):\n",
    "    print(f\"Fold {fold+1}\")\n",
    "\n",
    "    Xtr, Xva = X[tr], X[va]\n",
    "    ytr, yva = y[tr], y[va]\n",
    "\n",
    "    Xtr, ytr = sm.fit_resample(Xtr, ytr)\n",
    "\n",
    "    # XGB\n",
    "    xgb_model = xgb.XGBClassifier(\n",
    "        n_estimators=2000,\n",
    "        max_depth=8,\n",
    "        learning_rate=0.01,\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.7,\n",
    "        scale_pos_weight=ratio,\n",
    "        eval_metric='aucpr',\n",
    "        tree_method='hist'\n",
    "    )\n",
    "    xgb_model.fit(Xtr, ytr, eval_set=[(Xva,yva)], verbose=False)\n",
    "\n",
    "    xgb_oof[va] = xgb_model.predict_proba(Xva)[:,1]\n",
    "    xgb_test += xgb_model.predict_proba(X_test)[:,1]/5\n",
    "\n",
    "    # LGB\n",
    "    lgb_model = lgb.LGBMClassifier(\n",
    "        n_estimators=2000,\n",
    "        learning_rate=0.01,\n",
    "        num_leaves=255,\n",
    "        is_unbalance=True\n",
    "    )\n",
    "    lgb_model.fit(\n",
    "        Xtr, ytr,\n",
    "        eval_set=[(Xva,yva)],\n",
    "        callbacks=[lgb.early_stopping(100, verbose=False)]\n",
    "    )\n",
    "\n",
    "    lgb_oof[va] = lgb_model.predict_proba(Xva)[:,1]\n",
    "    lgb_test += lgb_model.predict_proba(X_test)[:,1]/5\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 5. STACKING\n",
    "# =========================================================\n",
    "stack = LogisticRegression()\n",
    "stack.fit(np.vstack([xgb_oof,lgb_oof]).T, y)\n",
    "\n",
    "blend_oof = stack.predict_proba(np.vstack([xgb_oof,lgb_oof]).T)[:,1]\n",
    "blend_test = stack.predict_proba(np.vstack([xgb_test,lgb_test]).T)[:,1]\n",
    "\n",
    "# =========================================================\n",
    "# 6. TRANSFORMER MODEL\n",
    "# =========================================================\n",
    "SEQ_LEN = 12\n",
    "\n",
    "def create_sequences(X, y=None):\n",
    "    Xs, ys = [], []\n",
    "    for i in range(len(X)-SEQ_LEN):\n",
    "        Xs.append(X[i:i+SEQ_LEN])\n",
    "        if y is not None:\n",
    "            ys.append(y[i+SEQ_LEN])\n",
    "    return np.array(Xs), np.array(ys)\n",
    "\n",
    "X_seq, y_seq = create_sequences(X, y)\n",
    "X_test_seq, _ = create_sequences(X_test)\n",
    "\n",
    "def positional_encoding(seq_len, d_model):\n",
    "    pos = np.arange(seq_len)[:, None]\n",
    "    i = np.arange(d_model)[None, :]\n",
    "    angle = pos / np.power(10000, (2*(i//2))/d_model)\n",
    "    angle[:, 0::2] = np.sin(angle[:, 0::2])\n",
    "    angle[:, 1::2] = np.cos(angle[:, 1::2])\n",
    "    return tf.cast(angle[None,...], tf.float32)\n",
    "\n",
    "def transformer_block(x):\n",
    "    attn = layers.MultiHeadAttention(num_heads=4, key_dim=64)(x,x)\n",
    "    x = layers.LayerNormalization()(x+attn)\n",
    "\n",
    "    ffn = layers.Dense(128, activation='relu')(x)\n",
    "    ffn = layers.Dense(x.shape[-1])(ffn)\n",
    "\n",
    "    return layers.LayerNormalization()(x+ffn)\n",
    "\n",
    "def build_model(input_shape):\n",
    "    inp = tf.keras.Input(shape=input_shape)\n",
    "\n",
    "    x = inp + positional_encoding(input_shape[0], input_shape[1])\n",
    "\n",
    "    for _ in range(2):\n",
    "        x = transformer_block(x)\n",
    "\n",
    "    x = layers.GlobalAveragePooling1D()(x)\n",
    "    x = layers.Dense(64, activation='relu')(x)\n",
    "    x = layers.Dropout(0.2)(x)\n",
    "\n",
    "    out = layers.Dense(1, activation='sigmoid')(x)\n",
    "\n",
    "    model = tf.keras.Model(inp,out)\n",
    "\n",
    "    model.compile(\n",
    "        optimizer=tf.keras.optimizers.Adam(1e-3),\n",
    "        loss='binary_crossentropy',\n",
    "        metrics=[tf.keras.metrics.AUC()]\n",
    "    )\n",
    "\n",
    "    return model\n",
    "\n",
    "model = build_model(X_seq.shape[1:])\n",
    "\n",
    "model.fit(\n",
    "    X_seq, y_seq,\n",
    "    epochs=20,\n",
    "    batch_size=256,\n",
    "    validation_split=0.2,\n",
    "    callbacks=[tf.keras.callbacks.EarlyStopping(patience=5, restore_best_weights=True)],\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "trans_preds = model.predict(X_test_seq).flatten()\n",
    "\n",
    "trans_full = np.zeros(len(X_test))\n",
    "trans_full[SEQ_LEN:] = trans_preds\n",
    "\n",
    "# =========================================================\n",
    "# 7. FINAL ENSEMBLE\n",
    "# =========================================================\n",
    "final_test = 0.4*blend_test + 0.6*trans_full\n",
    "\n",
    "# =========================================================\n",
    "# 8. THRESHOLD\n",
    "# =========================================================\n",
    "thresholds = np.arange(0.01,0.5,0.005)\n",
    "scores = [f1_score(y,(blend_oof>=t).astype(int)) for t in thresholds]\n",
    "\n",
    "best_t = thresholds[np.argmax(scores)]\n",
    "print(\"BEST THRESHOLD:\", best_t)\n",
    "\n",
    "# =========================================================\n",
    "# 9. FINAL PREDICTIONS\n",
    "# =========================================================\n",
    "preds = (final_test >= best_t).astype(int)\n",
    "\n",
    "# smoothing\n",
    "for i in range(2,len(preds)-2):\n",
    "    if preds[i]==0 and sum(preds[i-2:i+3])>=3:\n",
    "        preds[i]=1\n",
    "\n",
    "id_col = next(c for c in ['ID','Id','id'] if c in test.columns)\n",
    "\n",
    "sub = pd.DataFrame({\n",
    "    id_col: test[id_col],\n",
    "    'target': preds\n",
    "})\n",
    "\n",
    "sub.to_parquet(\"submission.parquet\", index=False)\n",
    "\n",
    "print(\"DONE\")\n",
    "print(\"Positive rate:\", preds.mean())"
   ]
  }
 ],
